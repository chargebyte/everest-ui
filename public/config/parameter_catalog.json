{
  "modules": {
    "safety": {
      "title": "Safety Controller",
      "actions": {
        "read_settings": {
          "group": "safety",
          "action": "read_settings",
          "parameters_mode": "empty"
        },
        "write_settings": {
          "group": "safety",
          "action": "write_settings",
          "parameters_mode": "from_catalog"
        }
      },
      "settings_matrix": [
        {
          "id": "pt1000",
          "display_name": "PT1000 Resistors",
          "instances": [
            { "id": "0", "display_name": "PT1000 1" },
            { "id": "1", "display_name": "PT1000 2" },
            { "id": "2", "display_name": "PT1000 3" },
            { "id": "3", "display_name": "PT1000 4" }
          ],
          "fields": [
            {
              "id": "overtemperature_threshold",
              "display_name": "Overtemperature Threshold",
              "description": "Shutdown threshold for this PT1000 channel.",
              "value_type": "float",
              "unit": "degC",
              "backend_path": "pt1000_{instance}.overtemperature_threshold"
            },
            {
              "id": "temperature_calibration",
              "display_name": "Temperature Calibration",
              "description": "Calibration offset/resistance for this PT1000 channel.",
              "value_type": "float",
              "unit": "ohm",
              "backend_path": "pt1000_{instance}.temperature_calibration"
            },
            {
              "id": "overtemperature_protection",
              "display_name": "Overtemperature Protection",
              "description": "Enable or disable PT1000 channel protection.",
              "value_type": "boolean",
              "backend_path": "pt1000_{instance}.overtemperature_protection"
            }
          ]
        },
        {
          "id": "contactors",
          "display_name": "Contactors",
          "instances": [
            { "id": "contactor1", "display_name": "Contactor 1" },
            { "id": "contactor2", "display_name": "Contactor 2" }
          ],
          "fields": [
            {
              "id": "mode",
              "display_name": "Mode",
              "description": "fill in later",
              "value_type": "enum",
              "enum_values": [
                "disabled",
                "without-feedback",
                "with-feedback"
              ],
              "backend_path": "contactors_{instance}.mode"
            }
          ]
        },
        {
          "id": "estops",
          "display_name": "Emergency Stops",
          "instances": [
            { "id": "estop1", "display_name": "E-Stop 1" },
            { "id": "estop2", "display_name": "E-Stop 2" },
            { "id": "estop3", "display_name": "E-Stop 3" }
          ],
          "fields": [
            {
              "id": "enabled",
              "display_name": "Enabled",
              "description": "fill in later",
              "value_type": "boolean",
              "backend_path": "estops_{instance}.enabled"
            }
          ]
        }
      ]
    },
